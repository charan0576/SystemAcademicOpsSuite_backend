# MongoDB Configuration
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=campus_connect_hub

# JWT Configuration
SECRET_KEY=your-secret-key-change-in-production-min-32-chars-12345678
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS Origins (Frontend URLs) - Add all ports your frontend might use
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:3000

# Environment
ENVIRONMENT=development
