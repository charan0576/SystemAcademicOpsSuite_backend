# ── LOCAL DEVELOPMENT ──────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=campus_connect_hub
SECRET_KEY=change-this-to-a-random-32-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
ENVIRONMENT=development

# ── RENDER PRODUCTION (set these in Render Dashboard → Environment) ──
# MONGODB_URL=mongodb+srv://<user>:<pass>@cluster.mongodb.net/campus_connect_hub
# DATABASE_NAME=campus_connect_hub
# SECRET_KEY=<auto-generated by Render or paste your own>
# ALLOWED_ORIGINS=https://your-app.vercel.app
# ENVIRONMENT=production
